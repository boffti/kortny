{
    "display_information": {
        "name": "Kortny",
        "description": "Your AI coworker",
        "background_color": "#10396e"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": true,
            "messages_tab_enabled": false,
            "messages_tab_read_only_enabled": false
        },
        "assistant_view": {
            "assistant_description": "Kortny is your AI coworker — ask it to research, draft, analyze data, track decisions, and automate recurring work across your workspace."
        },
        "bot_user": {
            "display_name": "Kortny",
            "always_online": true
        }
    },
    "oauth_config": {
        "redirect_urls": [
            "http://localhost:8080/auth/slack/callback"
        ],
        "scopes": {
            "bot": [
                "canvases:read",
                "app_mentions:read",
                "channels:history",
                "channels:read",
                "chat:write",
                "chat:write.customize",
                "files:read",
                "files:write",
                "groups:history",
                "groups:read",
                "im:history",
                "im:read",
                "im:write",
                "metadata.message:read",
                "mpim:history",
                "mpim:read",
                "mpim:write",
                "reactions:read",
                "reactions:write",
                "team:read",
                "users:read",
                "users:read.email",
                "canvases:write",
                "bookmarks:read",
                "bookmarks:write",
                "links:read",
                "links:write",
                "reminders:read",
                "reminders:write",
                "assistant:write"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_home_opened",
                "app_mention",
                "assistant_thread_context_changed",
                "assistant_thread_started",
                "member_joined_channel",
                "message.channels",
                "message.groups",
                "message.im",
                "message.mpim",
                "reaction_added"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}